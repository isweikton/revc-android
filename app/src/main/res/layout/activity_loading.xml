<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/loadingBackground"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="32dp"
    android:paddingTop="24dp"
    android:paddingEnd="32dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/loadingEyebrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="0.88"
        android:letterSpacing="0.08"
        android:text="@string/loading_caption"
        android:textAllCaps="true"
        android:textColor="@color/loadingAccent"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/loadingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/loading_title"
        android:textColor="@android:color/white"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/loadingSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:alpha="0.82"
        android:text="@string/loading_subtitle"
        android:textColor="@android:color/white"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:background="@drawable/loading_panel"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/loadingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loading_checking_files"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/loadingProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:minHeight="8dp"
            app:indicatorColor="@color/loadingAccent"
            app:trackColor="@color/loadingTrack"
            app:trackCornerRadius="4dp" />
    </LinearLayout>
</LinearLayout>
